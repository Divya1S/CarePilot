# Relay configuration — copy to a real secrets store (do NOT commit filled values).

# --- LLM (Reconciler + drafters) -------------------------------------------
# Provider-agnostic adapter (see llm.py). Gemini example:
RELAY_LLM_API_KEY=
RELAY_LLM_PROVIDER=openai
RELAY_LLM_MODEL=gemini-2.5-flash
RELAY_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# Force offline mode (fixtures/templates, no LLM). Leave blank normally.
RELAY_MOCK=

# --- Access gate (REQUIRED for any public deployment) ----------------------
# Any request needs HTTP Basic auth with this password (any username). If unset,
# the gate is OFF — never deploy to a public URL without setting this.
RELAY_ACCESS_PASSWORD=

# --- Google Calendar (optional; mock calendar used when unset) -------------
GOOGLE_APPLICATION_CREDENTIALS=
RELAY_CALENDAR_ID=

# --- Behaviour -------------------------------------------------------------
# Proactive Watcher cadence in seconds (0 disables; default 120).
RELAY_WATCH_INTERVAL=120
# SQLite path (mount a volume here in production to persist state).
RELAY_DB=backend/relay.db
